{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store items available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "description", "price", "category", "imageUrl", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "shippingAddress": { "type": "object" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "orderStatus": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "customerName", "items", "shippingAddress", "subtotal", "tax", "discount", "total", "paymentMethod", "paymentStatus", "orderStatus", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account configurations.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "object" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "role"]
    },
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Global store checkout configurations for tax and delivery fees.",
      "type": "object",
      "properties": {
        "cgstPercent": { "type": "number" },
        "sgstPercent": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "freeShippingThreshold": { "type": "number" }
      },
      "required": ["cgstPercent", "sgstPercent", "deliveryCharge", "freeShippingThreshold"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Public storefront product catalog"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Purchase orders placed by customers"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Customer and administrator user profiles"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/StoreSettings" },
      "description": "Global checkout settings including tax percentages and delivery fees"
    }
  }
}
